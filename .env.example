# Copy this file to .env and fill in values. Do not commit .env to GitHub.
#
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)

# Required. Generate a new key for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# True for local development, False on PythonAnywhere
DEBUG=True

# Comma-separated hosts. Example for PythonAnywhere:
# ALLOWED_HOSTS=yourusername.pythonanywhere.com
ALLOWED_HOSTS=127.0.0.1,localhost
